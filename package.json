{
  "name": "eligibil",
  "version": "1.0.0",
  "description": "AI-powered grant matching platform for startups in Moldova, Romania & EU",
  "main": "server.js",
  "homepage": "https://eligibil.eu",
  "keywords": [
    "grants",
    "startups",
    "AI",
    "pgvector",
    "embeddings",
    "Moldova",
    "Romania",
    "EU",
    "funding",
    "accelerator"
  ],
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "seed": "node scripts/seed-grants.js",
    "seed:dry": "node scripts/seed-grants.js --dry-run",
    "db:push": "node scripts/push-schema.js",
    "grants:process": "node scripts/process-grants-inbox.js",
    "grants:process:dry": "node scripts/process-grants-inbox.js --dry-run",
    "grants:sync": "node scripts/sync-obsidian.js",
    "grants:pull": "node scripts/sync-obsidian.js --pull",
    "grants:push": "node scripts/sync-obsidian.js --push",
    "grants:gmail": "node scripts/gmail-poller.js",
    "grants:scrape": "node scripts/web-scrapers.js",
    "grants:fetch": "node scripts/cron-fetch.js",
    "stats:refresh": "node scripts/compute-user-stats.js",
    "stats:rescore": "node scripts/compute-user-stats.js --sync-json --rescore"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "dotenv": "^16.5.0",
    "express": "^4.22.1",
    "express-session": "^1.19.0",
    "imapflow": "^1.3.2",
    "mailparser": "^3.9.8",
    "openai": "^4.96.2",
    "pg": "^8.13.3",
    "rss-parser": "^3.13.0",
    "xlsx": "^0.18.5"
  }
}
