{
  "name": "eligibil",
  "version": "1.0.0",
  "description": "AI-powered grant matching platform for startups in Moldova, Romania & EU",
  "main": "server.js",
  "homepage": "https://eligibil.org",
  "keywords": [
    "grants",
    "startups",
    "AI",
    "pgvector",
    "embeddings",
    "Moldova",
    "Romania",
    "EU",
    "funding",
    "accelerator"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "start": "node server.js",
    "dev": "node --watch server.js",
    "verify:prod": "node scripts/verify-production.js",
    "audit:files": "node scripts/check-required-files.js",
    "audit:i18n": "node scripts/i18n-audit.js",
    "smoke:pages": "node scripts/smoke-pages.js",
    "seed": "node scripts/seed-grants.js",
    "seed:dry": "node scripts/seed-grants.js --dry-run",
    "db:push": "node scripts/push-schema.js",
    "grants:process": "node scripts/process-grants-inbox.js",
    "grants:process:dry": "node scripts/process-grants-inbox.js --dry-run",
    "grants:sync": "node scripts/sync-obsidian.js",
    "grants:pull": "node scripts/sync-obsidian.js --pull",
    "grants:push": "node scripts/sync-obsidian.js --push",
    "grants:gmail": "node scripts/gmail-poller.js",
    "grants:scrape": "node scripts/web-scrapers.js",
    "grants:fetch": "node scripts/cron-fetch.js",
    "resources:import": "node scripts/import-funding-resources.js",
    "resources:import:dry": "node scripts/import-funding-resources.js --dry-run",
    "resources:describe": "node scripts/generate-resource-descriptions.js",
    "resources:describe:dry": "node scripts/generate-resource-descriptions.js --dry-run",
    "emails:deadline-alerts": "node scripts/send-deadline-alerts.js",
    "stats:refresh": "node scripts/compute-user-stats.js",
    "stats:rescore": "node scripts/compute-user-stats.js --sync-json --rescore",
    "grants:enrich": "node scripts/enrich-grants-claude.js",
    "grants:enrich:dry": "node scripts/enrich-grants-claude.js --dry-run",
    "security:audit": "npm audit --audit-level=high",
    "security:fix": "npm audit fix",
    "security:check": "npx better-npm-audit audit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@sentry/node": "^10.53.1",
    "@sentry/profiling-node": "^10.53.1",
    "@supabase/supabase-js": "^2.49.4",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "dotenv": "^16.5.0",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "imapflow": "^1.3.2",
    "mailparser": "^3.9.8",
    "multer": "^2.1.1",
    "openai": "^4.96.2",
    "pdf-parse": "^2.4.5",
    "pg": "^8.13.3",
    "resend": "^6.12.3",
    "rss-parser": "^3.13.0",
    "zod": "^3.25.76"
  }
}
