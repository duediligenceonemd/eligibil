# ── Supabase ──────────────────────────────────────────────────────────────────
# Găsești valorile în: Supabase Dashboard → Settings → API
# Folosește SERVICE ROLE key (nu anon key) — bypass Row Level Security pe server
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Direct PostgreSQL access (pentru push-schema.js și migrări)
# Parola din: Supabase Dashboard → Settings → Database → Database password
DB_PASSWORD=

# ── OpenAI (embeddings pentru vector search) ──────────────────────────────────
# Opțional — fără el, sistemul folosește full-text search ca fallback
# Cost seed: ~70 granturi × 400 tokens = <$0.001 total (text-embedding-3-small)
OPENAI_API_KEY=

# ── Anthropic (Claude API pentru extragere granturi din emails) ───────────────
# Opțional — fără el, sistemul folosește extracție heuristică (regex-based)
# Cost: ~$0.003 per email procesat (claude-sonnet-4-5)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ── Grants pipeline ───────────────────────────────────────────────────────────
# Folder pentru emails .eml/.txt de procesat
GRANTS_INBOX=./inbox
# Path către vault-ul Obsidian (default: ~/eligibil-grants)
OBSIDIAN_VAULT=
# Auto-approve granturi cu scor de relevance ≥ acest prag (0-100)
AUTO_APPROVE_SCORE=85

# ── Gmail IMAP (auto-fetch grant emails) ──────────────────────────────────────
# Get App Password at: https://myaccount.google.com/apppasswords
# Then create a Gmail label "grants-new" with filters for funding emails
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_LABEL=grants-new
GMAIL_PROCESSED_LABEL=grants-processed

# ── Admin ─────────────────────────────────────────────────────────────────────
# Token pentru acces la /api/admin fără login (header: x-admin-token)
ADMIN_TOKEN=

# ── Express ───────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=
PORT=3000

# ── Stripe (viitoare integrare plăți) ─────────────────────────────────────────
# Datele de card trec DIRECT prin Stripe Elements — NICIODATĂ pe serverul tău
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
