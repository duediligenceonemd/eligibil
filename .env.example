# ── Supabase ──────────────────────────────────────────────────────────────────
# Găsești valorile în: Supabase Dashboard → Settings → API
# Folosește SERVICE ROLE key (nu anon key) — bypass Row Level Security pe server
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Direct PostgreSQL access (pentru push-schema.js și migrări)
# Parola din: Supabase Dashboard → Settings → Database → Database password
DB_PASSWORD=

# ── AWS Bedrock (recommended — uses AWS Activate credits) ────────────────────
# Replaces both OpenAI and Anthropic when configured.
# Enable in: AWS Console → Bedrock → Model access → enable Titan Embed + Claude
# IAM: create user with AmazonBedrockFullAccess policy
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
# Set to 1 to switch embeddings from OpenAI to Bedrock Titan Embed V2.
# WARNING: Titan outputs 1024-dim vectors vs OpenAI 1536-dim — requires
# re-generating ALL embeddings and updating pgvector column dimension.
AWS_BEDROCK_EMBEDDINGS=0
# Override Bedrock model IDs (defaults shown):
# AWS_CHAT_MODEL=anthropic.claude-sonnet-4-5-20250929-v1:0
# AWS_EMBED_MODEL=amazon.titan-embed-text-v2:0

# ── OpenAI (embeddings fallback — used when AWS not configured) ──────────────
# Cost seed: ~70 granturi × 400 tokens = <$0.001 total (text-embedding-3-small)
OPENAI_API_KEY=
GA_MEASUREMENT_ID=
SENTRY_DSN=
SENTRY_ENABLE_LOGS=true
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_PROFILE_SESSION_SAMPLE_RATE=0.1
SENTRY_PROFILE_LIFECYCLE=trace
SENTRY_SEND_DEFAULT_PII=false
ENABLE_SENTRY_DEBUG_ROUTE=false

# ── Anthropic (Claude API fallback — used when AWS not configured) ───────────
# Cost: ~$0.003 per email procesat (claude-sonnet-4-5)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ── Grants pipeline ───────────────────────────────────────────────────────────
# Folder pentru emails .eml/.txt de procesat
GRANTS_INBOX=./inbox
# Path către vault-ul Obsidian (default: ~/eligibil-grants)
OBSIDIAN_VAULT=
# Auto-approve granturi cu scor de relevance ≥ acest prag (0-100)
AUTO_APPROVE_SCORE=85

# ── Gmail IMAP (auto-fetch grant emails) ──────────────────────────────────────
# Get App Password at: https://myaccount.google.com/apppasswords
# Then create a Gmail label "grants-new" with filters for funding emails
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_LABEL=grants-new
GMAIL_PROCESSED_LABEL=grants-processed

# ── Admin ─────────────────────────────────────────────────────────────────────
# Token pentru acces la /api/admin fără login (header: x-admin-token)
ADMIN_TOKEN=replace-with-a-long-random-admin-token
ALLOW_ADMIN_TOKEN_AUTH=false
ADMIN_EMAILS=admin@eligibil.org

# ── Express ───────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace-with-a-64-character-random-secret
SESSION_STORE=memory
SESSION_TABLE=app_sessions
SESSION_MAX_AGE_MS=86400000
SITE_URL=https://eligibil.org
PORT=3000
PASSWORD_RESET_TTL_MINUTES=30

# ── Resend (email sending) ────────────────────────────────────────────────────
# Sign up at resend.com, verify domain eligibil.org (add SPF, DKIM, DMARC DNS records)
RESEND_API_KEY=re_...
EMAIL_FROM=eligibil.org <noreply@eligibil.org>
EMAIL_REPLY_TO=admin@eligibil.org
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
UNSUBSCRIBE_SECRET=
BASE_URL=https://eligibil.org
DEADLINE_ALERT_DAYS=14,7,3

# ── Stripe (viitoare integrare plăți) ─────────────────────────────────────────
# Datele de card trec DIRECT prin Stripe Elements — NICIODATĂ pe serverul tău
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
